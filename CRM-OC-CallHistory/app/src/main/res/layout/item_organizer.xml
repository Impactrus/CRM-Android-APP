<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/client_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nazwa Kontrahenta"
            android:textColor="@color/crm_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/client_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="ul. Przykładowa 12, Wrocław"
            android:textColor="@color/crm_body"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/client_coords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="51.107885, 17.038538"
            android:textColor="@color/crm_placeholder"
            android:textSize="11sp" />

        <!-- Note section if exists -->
        <LinearLayout
            android:id="@+id/note_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ostatnia wizyta:"
                android:textColor="@color/crm_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/client_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ustalono warunki dostawy na rzepak."
                android:textColor="@color/crm_heading"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btn_simulate"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="Symuluj wizytę"
                android:textColor="@color/crm_primary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_add_note"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="@color/crm_primary"
                android:text="Notatka"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
