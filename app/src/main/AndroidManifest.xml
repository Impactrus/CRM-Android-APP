<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wizyty (GPS visit detection): location, activity recognition, foreground
         service (location type), and geofence re-registration after reboot. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".OssadkowskiApp"
        android:allowBackup="false"
        android:icon="@drawable/logo"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.OssadkowskiApp"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <meta-data
            android:name="co.tomtom.apiKey"
            android:value="e2ab4530-51b9-416a-8312-c6e61964ebf6" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".DashboardActivity" />
        <activity android:name=".ConversationsActivity" />
        <activity android:name=".ui.chat.ChatActivity" />
        <activity android:name=".NewRequestActivity" />
        <activity android:name=".ApprovalActivity" />
        <activity android:name=".ApprovalDetailActivity" />
        <activity android:name=".SalesListActivity" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity android:name=".TasksListActivity" />
        <activity android:name=".TaskDetailActivity" />
        <activity android:name=".CalendarActivity" />
        <activity android:name=".LimityKredytoweListActivity" />
        <activity android:name=".LimitKredytowyDetailActivity" />
        <activity android:name=".LimitKredytowyActivity" />
        <activity android:name=".EditRequestActivity" />
        <activity android:name=".OfertaActivity" />
        <activity android:name=".KnowledgeBaseActivity" />
        <activity android:name=".DebtTasksListActivity" />
        <activity android:name=".NewDebtTaskActivity" />
        
        <activity android:name=".TowarSearchActivity" />
        <activity android:name=".SalesOrdersActivity" />
        <activity android:name=".SalesOrderDetailActivity" />
        
        <!-- HR Module -->
        <activity android:name=".HrHistoriaWnioskowActivity" />
        <activity android:name=".HrKalendarzZamrozenActivity" />
        <activity android:name=".HrNadgodzinyActivity" />
        <activity android:name=".HrHomeOfficeActivity" />
        <activity android:name=".HrPrawoPracyActivity" />
        <activity android:name=".HrSchematOrgActivity" />
        <activity android:name=".ui.vacation.UrlopyRoczneActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <!-- Transport -->
        <activity android:name=".TransportListActivity" />
        <activity android:name=".NewTransportPriceActivity" />
        <activity android:name=".GrainContractsListActivity" />
        <activity android:name=".NewGrainContractActivity" />
        <activity android:name=".GrainContractDetailActivity" />
        <activity android:name=".HandlowcyListActivity" android:exported="false" />
        <activity android:name=".CustomerPanelActivity" android:exported="false" />
        <activity android:name=".WindykacjaKontrahentActivity" android:exported="false" />
        <activity android:name=".ui.sales.AxContractSearchActivity" />

        <!-- Serwis (field-service) Compose host -->
        <activity
            android:name=".ui.serwis.SerwisActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode" />

        <!-- Zamówienia nawozy (fertiliser-order) Compose host -->
        <activity
            android:name=".ui.nawozy.ZamowieniaNawozyActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode" />

        <!-- Wizyty (GPS visit detection) Compose host. -->
        <activity
            android:name=".ui.wizyty.WizytyActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode" />

        <!-- Wizyty detection engine: foreground service (location type) runs only during
             an active work session; geofence/activity receivers are app-internal; the
             boot receiver re-registers geofences after a reboot. -->
        <service
            android:name=".data.wizyty.location.VisitDetectionForegroundService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <receiver
            android:name=".data.wizyty.location.GeofenceBroadcastReceiver"
            android:exported="false" />

        <receiver
            android:name=".data.wizyty.location.ActivityTransitionReceiver"
            android:exported="false" />

        <receiver
            android:name=".data.wizyty.location.BootCompletedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        
        <activity
            android:name=".KontrahentSearchActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.OssadkowskiApp" />
        
        <!-- Throwaway example feature for the Clean Architecture scaffolding.
             Not in any launcher / drawer; reachable only via:
             adb shell am start -n com.ossadkowski.crm.mobile/.example.serverstatus.ui.ServerStatusActivity -->
        <activity
            android:name=".example.serverstatus.ui.ServerStatusActivity"
            android:exported="true"
            android:label="Server Status (debug)" />

        <activity
            android:name=".ui.transport.TransportMapActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <activity
            android:name=".ui.transport.TransportCenyListActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <activity
            android:name=".ui.transport.TransportCenyNewActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <activity
            android:name=".ui.transport.TransportCenyDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <activity
            android:name=".ui.delegacja.DelegacjaCreateActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <activity
            android:name=".ui.delegacja.DelegacjeMojeActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <activity
            android:name=".ui.delegacja.DelegacjeTeamActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <activity
            android:name=".ui.delegacja.DelegacjeRozliczActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <activity
            android:name=".ui.delegacja.DelegacjeZaliczkiActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <activity
            android:name=".ui.delegacja.DelegacjeAuditActivity"
            android:exported="false"
            android:theme="@style/Theme.OssadkowskiApp" />

        <service
            android:name=".fcm.CrmFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- FCM defaults for background-delivered notifications (when the app is killed
             or in the background and the push is a `notification` payload, the SDK
             auto-builds the notification and uses these). Without this the SDK falls
             back to the launcher icon (a colored PNG), which Android renders as a
             white square in the status bar and can drop silently on some OEMs. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/crm_primary" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="crm_notifications" />
    </application>

</manifest>
