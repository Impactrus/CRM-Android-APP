<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext only for dev server (remove in production once HTTPS is configured) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">crm.oc-serwer.pl</domain>
        <domain includeSubdomains="false">135.125.234.36</domain>
    </domain-config>
</network-security-config>
