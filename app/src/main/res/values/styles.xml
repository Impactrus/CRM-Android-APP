<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ======================== -->
    <!-- TEXT APPEARANCES          -->
    <!-- ======================== -->

    <!-- Base styles for dot-notation hierarchy -->
    <style name="TextAppearance.Crm" parent="TextAppearance.MaterialComponents.Body1" />
    <style name="Widget.Crm" parent="" />

    <style name="TextAppearance.Crm.Heading">
        <item name="android:textSize">@dimen/text_heading</item>
        <item name="android:textColor">@color/crm_heading</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Crm.Subheading">
        <item name="android:textSize">@dimen/text_subheading</item>
        <item name="android:textColor">@color/crm_heading</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Crm.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/crm_body</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Crm.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/crm_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Crm.Small">
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textColor">@color/crm_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Crm.Button">
        <item name="android:textSize">@dimen/text_subheading</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.Crm.Label">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/crm_heading</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Crm.Link">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/crm_primary_link</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ======================== -->
    <!-- COMPONENT STYLES         -->
    <!-- ======================== -->

    <!-- Top Bar -->
    <style name="Widget.Crm.TopBar">
        <item name="android:layout_height">@dimen/topbar_height</item>
        <item name="android:background">@drawable/bg_topbar</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Search Input -->
    <style name="Widget.Crm.SearchInput">
        <item name="android:layout_height">@dimen/search_height</item>
        <item name="android:background">@drawable/bg_search_bar</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/crm_body</item>
        <item name="android:textColorHint">@color/crm_placeholder</item>
    </style>

    <!-- Primary Button -->
    <style name="Widget.Crm.PrimaryButton">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textAppearance">@style/TextAppearance.Crm.Button</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">@dimen/spacing_xl</item>
        <item name="android:paddingEnd">@dimen/spacing_xl</item>
    </style>

    <!-- Secondary Button -->
    <style name="Widget.Crm.SecondaryButton">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textSize">@dimen/text_subheading</item>
        <item name="android:textColor">@color/crm_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">@dimen/spacing_xl</item>
        <item name="android:paddingEnd">@dimen/spacing_xl</item>
    </style>

    <!-- Card -->
    <style name="Widget.Crm.Card">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">@dimen/card_padding</item>
        <item name="android:layout_marginStart">@dimen/card_margin</item>
        <item name="android:layout_marginEnd">@dimen/card_margin</item>
        <item name="android:layout_marginBottom">@dimen/card_margin</item>
    </style>

    <!-- Status Badge -->
    <style name="Widget.Crm.StatusBadge">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">@dimen/spacing_sm</item>
        <item name="android:paddingEnd">@dimen/spacing_sm</item>
        <item name="android:paddingTop">@dimen/spacing_xs</item>
        <item name="android:paddingBottom">@dimen/spacing_xs</item>
        <item name="android:background">@drawable/bg_status_badge</item>
    </style>

    <!-- Tab -->
    <style name="Widget.Crm.Tab">
        <item name="android:layout_height">@dimen/tab_height</item>
        <item name="android:background">@drawable/bg_tab_inactive</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/crm_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
    </style>

    <!-- Tab Active -->
    <style name="Widget.Crm.TabActive" parent="Widget.Crm.Tab">
        <item name="android:background">@drawable/bg_tab_active</item>
        <item name="android:textColor">@color/crm_heading</item>
    </style>

    <!-- Form Input -->
    <style name="Widget.Crm.FormInput">
        <item name="android:layout_height">@dimen/input_height</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/crm_body</item>
        <item name="android:textColorHint">@color/crm_placeholder</item>
    </style>

    <!-- Form Label -->
    <style name="Widget.Crm.FormLabel">
        <item name="android:textAppearance">@style/TextAppearance.Crm.Label</item>
        <item name="android:paddingBottom">@dimen/spacing_xs</item>
    </style>

</resources>
