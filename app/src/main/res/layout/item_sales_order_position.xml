<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_input_field"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/pos_towar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textColor="@color/crm_heading"
        android:textSize="14sp"
        tools:text="NAWÓZ AZOTOWY (Towar przykładowy)"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- Ilość -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ilość"
                android:textSize="11sp"
                android:textColor="@color/crm_secondary"/>
            <TextView
                android:id="@+id/pos_ilosc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/crm_body"
                tools:text="10 szt."/>
        </LinearLayout>

        <!-- Cena -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cena (baz.)"
                android:textSize="11sp"
                android:textColor="@color/crm_secondary"/>
            <TextView
                android:id="@+id/pos_cena"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/crm_body"
                tools:text="150.00 PLN"/>
        </LinearLayout>

        <!-- Netto -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Netto"
                android:textSize="11sp"
                android:textColor="@color/crm_secondary"/>
            <TextView
                android:id="@+id/pos_netto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@color/crm_heading"
                tools:text="1500.00 PLN"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/pos_magazyn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/crm_secondary"
            tools:text="Magazyn główny" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" • "
            android:textSize="11sp"
            android:textColor="@color/crm_secondary" />
            
        <TextView
            android:id="@+id/pos_rabat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/crm_secondary"
            tools:text="Rabat: 5%" />
    </LinearLayout>

</LinearLayout>
