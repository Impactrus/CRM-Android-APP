<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_profile_card"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/columnHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/columnTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="Nowe"
            android:textColor="@color/crm_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/columnCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_count_badge"
            android:gravity="center"
            android:minWidth="24dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="1"
            android:textColor="@color/crm_secondary"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/columnArrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/arrow_down_float"
            app:tint="@color/crm_secondary" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/columnRecycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:visibility="gone" />
</LinearLayout>
