<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_bottom_sheet">

    <TextView
        android:id="@+id/tv_modal_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nowa wersja — Nazwa"
        android:textColor="@color/crm_heading"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#E0F2FE"
        android:padding="8dp"
        android:text="UWAGA: To jest szablon edycji (analogicznie do wersji web)."
        android:textColor="#0369A1"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Obowiązuje od *"
        android:textColor="@color/crm_secondary"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_date"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_input_field"
        android:hint="25.04.2026"
        android:paddingHorizontal="12dp"
        android:inputType="date" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Limit roczny *"
        android:textColor="@color/crm_secondary"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_limit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_input_field"
        android:hint="2"
        android:paddingHorizontal="12dp"
        android:inputType="numberDecimal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Podstawa prawna"
        android:textColor="@color/crm_secondary"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_basis"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_input_field"
        android:paddingHorizontal="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="end">

        <Button
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anuluj"
            android:textColor="@color/crm_secondary" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:backgroundTint="#84CC16"
            android:text="Zapisz wersję"
            android:textColor="@color/white" />

    </LinearLayout>

</LinearLayout>
