<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crm_surface"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:background="@color/white"
        android:elevation="@dimen/card_elevation"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_sm"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="@dimen/input_height"
            android:layout_height="@dimen/input_height"
            android:padding="@dimen/spacing_md"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/crm_body"
            android:contentDescription="@string/cd_back_button" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_xs"
            android:text="@string/calendar_title"
            android:textColor="@color/crm_heading"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Month navigation -->
    <LinearLayout
        android:id="@+id/month_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/input_height"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/spacing_sm"
        app:layout_constraintTop_toBottomOf="@id/topbar">

        <Button
            android:id="@+id/btn_prev_month"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="@dimen/input_height"
            android:layout_height="@dimen/tab_height"
            android:text="‹"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/month_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/crm_heading"
            android:textSize="@dimen/text_subheading"
            android:textStyle="bold"
            android:paddingHorizontal="@dimen/spacing_lg" />

        <Button
            android:id="@+id/btn_next_month"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="@dimen/input_height"
            android:layout_height="@dimen/tab_height"
            android:text="›"
            android:textSize="24sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/month_nav" />

    <!-- Zamrozenia list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_sm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/month_nav" />

    <TextView
        android:id="@+id/empty_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/calendar_empty"
        android:textColor="@color/crm_secondary"
        android:textSize="@dimen/text_body"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/month_nav" />

</androidx.constraintlayout.widget.ConstraintLayout>
