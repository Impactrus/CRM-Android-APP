<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA">

        <!-- Toolbar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_left"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/crm_heading" />

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kalendarz zadań"
                android:textColor="@color/crm_heading"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Month Navigation -->
        <LinearLayout
            android:id="@+id/month_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:gravity="center"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar">

            <ImageButton
                android:id="@+id/btn_prev_month"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/crm_primary" />

            <TextView
                android:id="@+id/month_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Kwiecień 2024"
                android:textColor="@color/crm_heading"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_next_month"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:rotation="180"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/crm_primary" />
        </LinearLayout>

        <!-- Week Day Headers -->
        <GridLayout
            android:id="@+id/week_headers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:paddingHorizontal="4dp"
            android:background="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/month_nav">

            <TextView style="@style/CrmCalendarWeekdayHeader" android:text="Pon" />
            <TextView style="@style/CrmCalendarWeekdayHeader" android:text="Wt" />
            <TextView style="@style/CrmCalendarWeekdayHeader" android:text="Śr" />
            <TextView style="@style/CrmCalendarWeekdayHeader" android:text="Czw" />
            <TextView style="@style/CrmCalendarWeekdayHeader" android:text="Pt" />
            <TextView style="@style/CrmCalendarWeekdayHeader" android:text="Sob" />
            <TextView style="@style/CrmCalendarWeekdayHeader" android:text="Ndz" />
        </GridLayout>

        <!-- Grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:padding="4dp"
            app:layout_constraintBottom_toTopOf="@+id/tasks_section_header"
            app:layout_constraintTop_toBottomOf="@id/week_headers"
            app:layout_constraintVertical_weight="1.2"
            tools:listitem="@layout/item_calendar_day" />

        <!-- Tasks Header — zawsze widoczny, pokazuje wybrany dzień -->
        <LinearLayout
            android:id="@+id/tasks_section_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintBottom_toTopOf="@+id/days_content_container"
            app:layout_constraintTop_toBottomOf="@id/recycler_view">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/crm_divider"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/selected_day_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wybierz dzień"
                android:textColor="@color/crm_heading"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Kontener na listę lub pusty stan — oba w tym samym miejscu -->
        <FrameLayout
            android:id="@+id/days_content_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tasks_section_header"
            app:layout_constraintVertical_weight="0.8">

            <!-- Lista zadań -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tasks_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                tools:listitem="@layout/item_task_detail_simple" />

            <!-- Pusty stan — nakłada się na RecyclerView w tym samym FrameLayout -->
            <TextView
                android:id="@+id/empty_tasks_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="32dp"
                android:text="BRAK ZADAŃ\nNA TEN DZIEŃ"
                android:textColor="#AAAAAA"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </FrameLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
