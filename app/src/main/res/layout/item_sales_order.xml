<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    android:layout_marginBottom="8dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/item_nr_zam"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/crm_heading"
                android:textSize="14sp"
                tools:text="#ZAM-20260422-2" />

            <TextView
                android:id="@+id/item_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_szkic"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/crm_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                tools:text="Szkic" />
        </LinearLayout>

        <TextView
            android:id="@+id/item_kontrahent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/crm_body"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            tools:text="AGROMOCNI KRUK I WSPÓLNICY SPÓŁKA JAWNA" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/crm_divider"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/item_ax_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/crm_placeholder"
                    android:textSize="11sp"
                    tools:text="AX: -" />

                <TextView
                    android:id="@+id/item_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/crm_secondary"
                    android:textSize="12sp"
                    tools:text="Ilość tow.: 0 | Data: 22.04.2026" />
            </LinearLayout>

            <TextView
                android:id="@+id/item_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/crm_heading"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                tools:text="0,00 PLN" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
