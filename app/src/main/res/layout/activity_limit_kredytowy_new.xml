<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crm_surface"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:background="@color/white"
        android:elevation="@dimen/card_elevation"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_sm"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="@dimen/input_height"
            android:layout_height="@dimen/input_height"
            android:padding="@dimen/spacing_md"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/crm_body"
            android:contentDescription="@string/cd_back_button" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_xs"
            android:text="@string/limit_new_title"
            android:textColor="@color/crm_heading"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Section: Kontrahent -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kontrahent_section_title"
                android:textColor="@color/crm_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_nazwa_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <EditText 
                        android:id="@+id/input_nazwa" 
                        android:layout_width="match_parent" 
                        android:layout_height="@dimen/input_height" 
                        android:background="@drawable/bg_input_field" 
                        android:hint="@string/search_kontrahent_hint" 
                        android:drawableStart="@drawable/ic_search"
                        android:drawablePadding="8dp"
                        android:paddingHorizontal="12dp" 
                        android:textSize="14sp" />
                    <ProgressBar
                        android:id="@+id/search_progress"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_nip_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_nip" android:layout_width="match_parent" android:layout_height="@dimen/input_height" android:background="@drawable/bg_input_field" android:inputType="number" android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_ax_num_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_ax_num" android:layout_width="match_parent" android:layout_height="@dimen/input_height" android:background="@drawable/bg_input_field" android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_adres_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_adres" android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/bg_input_field" android:gravity="top" android:padding="12dp" android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/limits_section_title"
                android:textColor="@color/crm_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_status_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_status" android:layout_width="match_parent" android:layout_height="@dimen/input_height" android:background="@drawable/bg_input_field" android:enabled="false" android:text="@string/lk_status_draft" android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_obecny_limit_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_obecny_limit" android:layout_width="match_parent" android:layout_height="@dimen/input_height" android:background="@drawable/bg_input_field" android:enabled="false" android:hint="0,00" android:inputType="numberDecimal" android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_wnioskowany_limit_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_limit" android:layout_width="match_parent" android:layout_height="@dimen/input_height" android:background="@drawable/bg_input_field" android:hint="0,00" android:inputType="numberDecimal" android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_zadluzenie_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_zadluzenie" android:layout_width="match_parent" android:layout_height="@dimen/input_height" android:background="@drawable/bg_input_field" android:enabled="false" android:hint="0,00" android:inputType="numberDecimal" android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <CheckBox
                    android:id="@+id/check_potwierdzone_przeterminowane"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lk_potwierdzone_przeterminowane_label"
                    android:textSize="13sp"
                    android:textColor="@color/crm_body" />

                <CheckBox
                    android:id="@+id/check_rozliczenie_plonami"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lk_rozliczenie_plonami_label"
                    android:textSize="13sp"
                    android:textColor="@color/crm_body"
                    android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_opis_zabezpieczen_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_opis_zabezpieczen" android:layout_width="match_parent" android:layout_height="80dp" android:background="@drawable/bg_input_field" android:gravity="top" android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_nowe_zabezpieczenia_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_nowe_zabezpieczenia" android:layout_width="match_parent" android:layout_height="80dp" android:background="@drawable/bg_input_field" android:gravity="top" android:padding="12dp" android:textSize="14sp" />
            </LinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/additional_section_title"
                android:textColor="@color/crm_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_termin_zabezpieczen_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_termin_zabezpieczen" android:layout_width="match_parent" android:layout_height="@dimen/input_height" android:background="@drawable/bg_input_field" android:hint="YYYY-MM-DD" android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_dodatkowe_dochody_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_dodatkowe_dochody" android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/bg_input_field" android:gravity="top" android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_zobowiazania_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_zobowiazania" android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/bg_input_field" android:gravity="top" android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_uwagi_label" android:textColor="@color/crm_heading" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/input_uwagi" android:layout_width="match_parent" android:layout_height="100dp" android:background="@drawable/bg_input_field" android:gravity="top" android:padding="12dp" android:textSize="14sp" />
            </LinearLayout>

            <!-- Observers -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lk_obserwatorzy_label" android:textStyle="bold" android:textColor="@color/crm_heading" android:layout_marginBottom="8dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">
                <TextView android:id="@+id/txt_observers" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Brak" android:textColor="@color/crm_secondary" android:textSize="14sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/lk_btn_save"
                android:backgroundTint="@color/crm_primary"
                android:textColor="@color/white"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
