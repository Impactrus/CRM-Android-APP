<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crm_surface"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:background="@color/white"
        android:elevation="@dimen/card_elevation"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_sm"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="@dimen/input_height"
            android:layout_height="@dimen/input_height"
            android:padding="@dimen/spacing_md"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/crm_body"
            android:contentDescription="@string/cd_back_button" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            android:text="@string/debt_new_task_title"
            android:textColor="@color/crm_heading"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintTop_toBottomOf="@id/topbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Section: Kontrahent -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/drawer_kontrahenci"
                android:textColor="@color/crm_blue"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/spacing_sm"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp"
                app:strokeColor="@color/crm_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/debt_task_kontrahent_label"
                        android:textColor="@color/crm_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/et_kontrahent_search"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_field"
                        android:hint="@string/search_kontrahent_hint"
                        android:inputType="text"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:textColor="@color/crm_heading"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Szczegóły zadania -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lk_section_details"
                android:textColor="@color/crm_blue"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/spacing_sm"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp"
                app:strokeColor="@color/crm_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Tytuł -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/debt_task_title_label"
                        android:textColor="@color/crm_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/et_tytul"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_field"
                        android:inputType="text"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:textColor="@color/crm_heading"
                        android:textSize="@dimen/text_body"
                        android:layout_marginBottom="@dimen/spacing_md"/>

                    <!-- Opis -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/debt_task_desc_label"
                        android:textColor="@color/crm_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/et_opis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_field"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:padding="@dimen/spacing_md"
                        android:textColor="@color/crm_heading"
                        android:textSize="@dimen/text_body"
                        android:layout_marginBottom="@dimen/spacing_md"/>

                    <!-- Termin -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/debt_task_termin_label"
                        android:textColor="@color/crm_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/et_termin"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_field"
                        android:drawableEnd="@drawable/ic_calendar"
                        android:focusable="false"
                        android:inputType="none"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:textColor="@color/crm_heading"
                        android:textSize="@dimen/text_body"
                        android:layout_marginBottom="@dimen/spacing_sm"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:backgroundTint="@color/crm_blue"
            android:text="@string/debt_task_btn_save"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radius_md" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
