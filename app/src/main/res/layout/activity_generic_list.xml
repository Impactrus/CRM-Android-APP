<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crm_surface"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:background="@color/white"
        android:elevation="@dimen/card_elevation"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_sm"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="@dimen/input_height"
            android:layout_height="@dimen/input_height"
            android:padding="@dimen/spacing_md"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/crm_body"
            android:contentDescription="@string/cd_back_button" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_xs"
            android:text="@string/no_results"
            android:textColor="@color/crm_heading"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/search_container"
        android:layout_width="match_parent"
        android:layout_height="@dimen/search_height"
        android:layout_marginHorizontal="@dimen/spacing_sm"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_search_bar"
        app:layout_constraintTop_toBottomOf="@id/topbar">

        <EditText
            android:id="@+id/search_input"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="@dimen/spacing_sm"
            android:hint="@string/search_hint"
            android:inputType="text"
            android:paddingHorizontal="@dimen/spacing_md"
            android:textColor="@color/crm_heading"
            android:textColorHint="@color/crm_secondary"
            android:textSize="@dimen/text_body" />
    </FrameLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxl"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container" />

    <TextView
        android:id="@+id/empty_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/no_results"
        android:textColor="@color/crm_secondary"
        android:textSize="@dimen/text_body"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        app:layout_constraintBottom_toTopOf="@id/pagination_layout"
        app:layout_constraintTop_toBottomOf="@id/search_container" />

    <LinearLayout
        android:id="@+id/pagination_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="@dimen/card_elevation"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/page_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:textColor="@color/crm_secondary"
            android:textSize="@dimen/text_body" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_prev"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="@dimen/pagination_btn_size"
                android:layout_height="@dimen/pagination_btn_size"
                android:enabled="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="‹"
                android:textSize="18sp"
                app:cornerRadius="@dimen/radius_sm"
                app:strokeColor="@color/crm_border" />

            <Button
                android:id="@+id/btn_next"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="@dimen/pagination_btn_size"
                android:layout_height="@dimen/pagination_btn_size"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="›"
                android:textSize="18sp"
                app:cornerRadius="@dimen/radius_sm"
                app:strokeColor="@color/crm_border" />
        </LinearLayout>
    </LinearLayout>
    
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_lg"
        android:src="@drawable/ic_add"
        android:visibility="gone"
        app:tint="@color/white"
        app:backgroundTint="@color/crm_blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/cd_add_button" />

</androidx.constraintlayout.widget.ConstraintLayout>
