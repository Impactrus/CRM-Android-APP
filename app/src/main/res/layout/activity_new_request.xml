<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crm_surface"
    android:fitsSystemWindows="true"
    tools:context=".NewRequestActivity">

    <!-- Topbar with Back Arrow -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/crm_primary"
            android:contentDescription="@string/cd_back_button"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/topbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/new_request_title"
            android:textSize="@dimen/text_heading"
            android:textStyle="bold"
            android:textColor="@color/crm_heading"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/back_button"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/topbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Request Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/request_type_label"
                android:textColor="@color/crm_heading"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            
            <Spinner
                android:id="@+id/spinner_request_type"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="16dp"/>

             <!-- Leave Type (Conditional logic in Kotlin) -->
            <TextView
                android:id="@+id/label_leave_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/leave_type_label"
                android:textColor="@color/crm_heading"
                android:textStyle="bold"
                 android:layout_marginBottom="8dp"/>
            
            <Spinner
                android:id="@+id/spinner_leave_type"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:background="@drawable/bg_input_field"
                 android:layout_marginBottom="16dp"/>

            <!-- Dates Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/date_from_label"
                        android:textStyle="bold"
                        android:textColor="@color/crm_heading"
                        android:layout_marginBottom="8dp"/>
                     <EditText
                        android:id="@+id/input_start_date"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_field"
                        android:hint="@string/date_hint"
                        android:paddingHorizontal="12dp"
                        android:textSize="@dimen/text_body"
                        android:focusable="false"
                        android:clickable="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                     <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/date_to_label"
                        android:textStyle="bold"
                        android:textColor="@color/crm_heading"
                        android:layout_marginBottom="8dp"/>
                     <EditText
                        android:id="@+id/input_end_date"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_field"
                        android:hint="@string/date_hint"
                        android:paddingHorizontal="12dp"
                        android:textSize="@dimen/text_body"
                        android:focusable="false"
                        android:clickable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Working days info -->
            <TextView
                android:id="@+id/working_days_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/crm_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

             <!-- Substitute -->
             <TextView
                android:id="@+id/label_substitute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/substitute_label"
                android:textColor="@color/crm_heading"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            
            <Spinner
                android:id="@+id/spinner_substitute"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="16dp"/>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/description_label"
                android:textColor="@color/crm_heading"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/input_description"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_input_field"
                android:gravity="top|start"
                android:padding="12dp"
                android:hint="@string/description_hint"
                android:textSize="@dimen/text_body"
                android:layout_marginBottom="24dp"/>

            <!-- Upload Section (Accordion) -->
            <LinearLayout
                android:id="@+id/upload_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_field"
                android:padding="12dp">

                <LinearLayout
                    android:id="@+id/upload_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/upload_title"
                        android:textSize="@dimen/text_subheading"
                        android:textStyle="bold"
                        android:textColor="@color/crm_heading" />

                    <ImageView
                        android:id="@+id/upload_chevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_drop_down"
                        app:tint="@color/crm_body" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/upload_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/photos_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btn_add_photo"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/add_photo"
                        android:textColor="@color/crm_primary"
                        app:strokeColor="@color/crm_primary"
                        app:strokeWidth="1dp"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconTint="@color/crm_primary"
                        app:iconGravity="textStart"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Praca Zdalna Section -->
            <LinearLayout
                android:id="@+id/section_remote_work"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Pozostale dni card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_field"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pozostała ilość dni"
                        android:textColor="@color/crm_heading"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/remote_work_remaining_days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/status_success_bg"
                        android:textColor="@color/status_success_text"
                        android:text="-- dni"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Adres wykonywania pracy -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wybierz adres"
                    android:textColor="@color/crm_heading"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinner_remote_address"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="16dp"/>

                <!-- Address Inputs Container (Ulica, nr, miasto, kod) -->
                <LinearLayout
                    android:id="@+id/container_address_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ulica"
                                android:textColor="@color/crm_heading"
                                android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/input_address_street"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_input_field"
                                android:paddingHorizontal="12dp"
                                android:textSize="@dimen/text_body"
                                android:inputType="textPostalAddress"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nr lokalu"
                                android:textColor="@color/crm_heading"
                                android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/input_address_number"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_input_field"
                                android:paddingHorizontal="12dp"
                                android:textSize="@dimen/text_body"
                                android:inputType="text"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Miasto"
                                android:textColor="@color/crm_heading"
                                android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/input_address_city"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_input_field"
                                android:paddingHorizontal="12dp"
                                android:textSize="@dimen/text_body"
                                android:inputType="text"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kod pocztowy"
                                android:textColor="@color/crm_heading"
                                android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/input_address_zip"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_input_field"
                                android:paddingHorizontal="12dp"
                                android:textSize="@dimen/text_body"
                                android:inputType="text"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Declarations Checkboxes -->
                <CheckBox
                    android:id="@+id/checkbox_bhp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Oświadczam, iż na stanowisku pracy zdalnej w wymienionym miejscu zapewnione są bezpieczne i higieniczne warunki pracy."
                    android:textSize="12sp"
                    android:textColor="@color/crm_body"
                    android:layout_marginBottom="8dp"/>

                <CheckBox
                    android:id="@+id/checkbox_rodo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Oświadczam, że w tym roku nie świadczyłem/świadczyłam pracy zdalnej okazjonalnej oraz zapoznałem/-łam się z przygotowaną przez pracodawcę oceną ryzyka zawodowego, informacją zawierającą zasady bezpiecznego i higienicznego wykonywania pracy zdalnej."
                    android:textSize="12sp"
                    android:textColor="@color/crm_body"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/submit_request"
                android:backgroundTint="@color/white"
                android:textColor="@color/crm_primary"
                app:strokeColor="@color/crm_primary"
                app:strokeWidth="1dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
