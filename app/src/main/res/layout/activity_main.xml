<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- Tractor photo background - top 44% -->
    <FrameLayout
        android:id="@+id/bg_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHeight_percent="0.44">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:scaleX="1.6"
            android:scaleY="1.6"
            android:src="@drawable/login_bg"
            android:contentDescription="@string/cd_login_background" />

        <!-- Green tint overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/crm_overlay" />

        <!-- White logo centered -->
        <ImageView
            android:id="@+id/logo_image"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/logo_white" />
    </FrameLayout>

    <!-- White card with rounded top corners -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:background="@drawable/bg_card_top_rounded"
        app:layout_constraintTop_toTopOf="@id/card_guideline"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <!-- Heading -->
            <TextView
                android:id="@+id/title_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:fontFamily="sans-serif"
                android:text="@string/login_welcome"
                android:textColor="@color/crm_heading"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Email Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/login_email_label"
                android:textColor="@color/crm_heading"
                android:textSize="@dimen/text_body" />

            <!-- Email Input -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_input_figma">

                <EditText
                    android:id="@+id/email_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:drawableStart="@drawable/ic_user"
                    android:drawablePadding="10dp"
                    android:hint="@string/login_email_hint"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/crm_heading"
                    android:textColorHint="@color/crm_secondary"
                    android:textSize="@dimen/text_body" />
            </FrameLayout>

            <!-- Password Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/login_password_label"
                android:textColor="@color/crm_heading"
                android:textSize="@dimen/text_body" />

            <!-- Password Input -->
            <FrameLayout
                android:id="@+id/password_container"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_input_figma">

                <EditText
                    android:id="@+id/password_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:drawableStart="@drawable/ic_user"
                    android:drawablePadding="10dp"
                    android:hint="@string/login_password_hint"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:paddingEnd="48dp"
                    android:textColor="@color/crm_heading"
                    android:textColorHint="@color/crm_secondary"
                    android:textSize="@dimen/text_body" />

                <ImageView
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end|center_vertical"
                    android:padding="10dp"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="@string/cd_toggle_password"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </FrameLayout>

            <!-- Inline error message -->
            <TextView
                android:id="@+id/login_error_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/login_error_inline"
                android:textColor="#EF4444"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Remember me & Forgot password -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <CheckBox
                    android:id="@+id/remember_me_checkbox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/crm_border"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/login_remember"
                    android:textColor="@color/crm_secondary"
                    android:textSize="@dimen/text_body" />

                <TextView
                    android:id="@+id/forgot_password_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/login_forgot_password"
                    android:textColor="@color/crm_primary_link"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

            <!-- Login Button -->
            <Button
                android:id="@+id/login_button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/crm_primary"
                android:fontFamily="sans-serif"
                android:text="@string/login_button"
                android:textAllCaps="false"
                android:textColor="@color/crm_dark_green"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <!-- Footer -->
            <TextView
                android:id="@+id/footer_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:text="@string/login_no_account"
                android:textColor="@color/crm_dark_green"
                android:textSize="@dimen/text_body" />

        </LinearLayout>
    </ScrollView>

    <!-- Guideline at 40% for card overlap -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/card_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.40" />

</androidx.constraintlayout.widget.ConstraintLayout>
