<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DashboardActivity">

    <!-- Main content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/crm_surface"
        android:fitsSystemWindows="true">

        <!-- Top Navbar -->
        <LinearLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/topbar_height"
            android:background="@color/white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="@string/cd_menu_button" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_search_bar">

                <EditText
                    android:id="@+id/global_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="8dp"
                    android:hint="@string/search_hint"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/crm_heading"
                    android:textColorHint="@color/crm_secondary"
                    android:textSize="@dimen/text_body" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/user_pill"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_tab_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/topbar_avatar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_initials_circle"
                    android:gravity="center"
                    android:textColor="#03543f"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="MK" />


                <TextView
                    android:id="@+id/topbar_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:maxWidth="100dp"
                    android:singleLine="true"
                    android:textColor="@color/crm_heading"
                    android:textSize="13sp"
                    tools:text="Andrzej K." />
            </LinearLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/topbar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Breadcrumb -->
                <TextView
                    android:id="@+id/breadcrumb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="8dp"
                    android:textColor="@color/crm_secondary"
                    android:textSize="13sp"
                    tools:text="Home  ›  Panel pracownika" />

                <!-- Profile & Summary Stats Container -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Profile Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_card"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/profile_avatar"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_avatar_square"
                            android:gravity="center"
                            android:textColor="@color/status_success_text"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            tools:text="M" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <TextView
                                    android:id="@+id/profile_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-black"
                                    android:textColor="@color/crm_heading"
                                    android:textSize="18sp"
                                    tools:text="MAREK" />

                                <TextView
                                    android:id="@+id/profile_badge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/bg_badge_active"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="2dp"
                                    android:text="✓ Aktywny"
                                    android:textColor="@color/status_success_text"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/profile_role"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableStart="@drawable/ic_user"
                                android:drawablePadding="6dp"
                                android:drawableTint="@color/crm_primary"
                                android:textColor="@color/crm_body"
                                android:textSize="13sp"
                                android:layout_marginBottom="2dp"
                                tools:text="Administrator AX, Analityk-Architekt AX" />

                            <TextView
                                android:id="@+id/profile_email"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableStart="@drawable/ic_email"
                                android:drawablePadding="6dp"
                                android:drawableTint="@color/crm_primary"
                                android:textColor="@color/crm_body"
                                android:textSize="13sp"
                                tools:text="m_perczuk@osadkowski-cebulski.pl" />
                                
                            <TextView
                                android:id="@+id/profile_phone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Top Summary Stats (2 Mini Cards) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_profile_card"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Dni wolne"
                                    android:textColor="@color/crm_secondary"
                                    android:textSize="12sp" />
                                <TextView
                                    android:id="@+id/summary_days_off"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/crm_heading"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="32" />
                            </LinearLayout>
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/crm_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_profile_card"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Zadania na dziś"
                                    android:textColor="@color/crm_secondary"
                                    android:textSize="12sp" />
                                <TextView
                                    android:id="@+id/summary_tasks"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/crm_heading"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="0" />
                            </LinearLayout>
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_task"
                                app:tint="@color/crm_primary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Detailed Stats (Dni wolne) -->
                    <LinearLayout
                        android:id="@+id/stat_days_off_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dni wolne"
                                android:textStyle="bold"
                                android:textColor="@color/crm_heading"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="FIREBIRD"
                                android:textColor="@color/crm_placeholder"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium" />
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:id="@+id/stat_days_off"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/crm_heading"
                                android:textSize="32sp"
                                android:fontFamily="sans-serif-black"
                                tools:text="32" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" dni pozostało"
                                android:textColor="@color/crm_secondary"
                                android:textSize="14sp"
                                android:layout_marginStart="8dp"
                                android:layout_marginBottom="4dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/stat_days_off_details"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/crm_body"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"
                            tools:text="Wykorzystane: 5 • Z poprzedniego roku: 11 • Dodatkowe: 0" />

                        <TextView
                            android:id="@+id/stat_days_off_limit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/crm_body"
                            android:textSize="12sp"
                            tools:text="Wymiar urlopu: 26 dni" />
                    </LinearLayout>

                    <!-- Detailed Stats (Praca zdalna) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dni praca zdalna"
                                android:textStyle="bold"
                                android:textColor="@color/crm_heading"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="LIMIT GLOBALNY"
                                android:textColor="@color/crm_placeholder"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium" />
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:id="@+id/stat_ho_remaining"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/crm_heading"
                                android:textSize="32sp"
                                android:fontFamily="sans-serif-black"
                                tools:text="24" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" dni pozostało"
                                android:textColor="@color/crm_secondary"
                                android:textSize="14sp"
                                android:layout_marginStart="8dp"
                                android:layout_marginBottom="4dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/stat_ho_details"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/crm_body"
                            android:textSize="12sp"
                            tools:text="Wykorzystane: 0 • Limit roczny: 24" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_logout"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/logout"
                        android:textColor="@color/status_error_text"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Serwis (field-service) tile — claim-gated; visibility set in code -->
                <LinearLayout
                    android:id="@+id/tile_serwis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_profile_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_initials_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_serwis"
                        android:contentDescription="@string/dashboard_tile_serwis" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/dashboard_tile_serwis"
                            android:textColor="@color/crm_heading"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_tile_serwis_subtitle"
                            android:textColor="@color/crm_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- Tab Bar — 2 Rows to fit screen -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="vertical">

                    <!-- First Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_tab_bar"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/tab_zadania"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tab_active"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:text="@string/tab_zadania"
                            android:textColor="@color/crm_body"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tab_board"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tab_inactive"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:text="Board"
                            android:textColor="@color/crm_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tab_akceptacje"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tab_inactive"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:text="Akceptacje"
                            android:textColor="@color/crm_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Second Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tab_bar"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/tab_wnioski"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tab_inactive"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:text="@string/tab_wnioski"
                            android:textColor="@color/crm_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tab_zastepstwa"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tab_inactive"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:text="Zastępstwa"
                            android:textColor="@color/crm_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tab_polecenie"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tab_inactive"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:text="Polecenie"
                            android:textColor="@color/crm_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Containers Stack -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Tasks Container -->
                    <LinearLayout
                        android:id="@+id/tasks_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="visible">

                        <EditText
                            android:id="@+id/tasks_search"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_search_bar"
                            android:drawableStart="@drawable/ic_search"
                            android:drawablePadding="8dp"
                            android:hint="@string/search_tasks_hint"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/crm_heading"
                            android:textColorHint="@color/crm_secondary"
                            android:textSize="@dimen/text_body"
                            android:layout_marginBottom="12dp" />

                        <ProgressBar
                            android:id="@+id/tasks_progress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:visibility="gone" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/tasks_recycler"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingTop="12dp">
                            <TextView
                                android:id="@+id/tasks_page_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="horizontal">
                                <Button
                                    android:id="@+id/tasks_btn_prev"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:enabled="false"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:text="‹"
                                    android:textSize="18sp"
                                    app:cornerRadius="4dp"
                                    app:strokeColor="@color/crm_border" />
                                <Button
                                    android:id="@+id/tasks_btn_next"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:text="›"
                                    android:textSize="18sp"
                                    app:cornerRadius="4dp"
                                    app:strokeColor="@color/crm_border" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Board Container -->
                    <LinearLayout
                        android:id="@+id/board_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="gone">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <Button android:id="@+id/btn_board_filter_my" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Moje" android:textSize="11sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                            <Button android:id="@+id/btn_board_filter_team" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Zespół" android:textSize="11sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                            <Button android:id="@+id/btn_board_filter_all" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Wszy." android:textSize="11sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                        </LinearLayout>

                        <ProgressBar android:id="@+id/board_progress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone" />
                        <androidx.recyclerview.widget.RecyclerView android:id="@+id/board_recycler" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Akceptacje Container -->
                    <LinearLayout
                        android:id="@+id/akceptacje_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="gone">
                        <ProgressBar android:id="@+id/akceptacje_progress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone" />
                        <TextView android:id="@+id/akceptacje_empty_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Brak wniosków do akceptacji" android:gravity="center" android:padding="20dp" android:visibility="gone" />
                        <androidx.recyclerview.widget.RecyclerView android:id="@+id/akceptacje_recycler" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Wnioski Container -->
                    <LinearLayout
                        android:id="@+id/wnioski_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="gone">
                        <Button
                            android:id="@+id/btn_new_wniosek"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="@string/wnioski_new_button"
                            android:textAllCaps="false"
                            android:textColor="@color/crm_primary"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/crm_primary" />
                        <ProgressBar android:id="@+id/wnioski_progress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone" />
                        <androidx.recyclerview.widget.RecyclerView android:id="@+id/wnioski_recycler" android:layout_width="match_parent" android:layout_height="wrap_content" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingTop="12dp">
                            <TextView android:id="@+id/wnioski_page_info" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                <Button android:id="@+id/wnioski_btn_prev" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="40dp" android:layout_height="40dp" android:text="‹" />
                                <Button android:id="@+id/wnioski_btn_next" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="40dp" android:layout_height="40dp" android:text="›" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Zastepstwa Container -->
                    <LinearLayout
                        android:id="@+id/zastepstwa_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="gone">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Oczekujące" android:textStyle="bold" />
                        <ProgressBar android:id="@+id/zastepstwa_oczekujace_progress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone" />
                        <TextView android:id="@+id/zastepstwa_oczekujace_empty_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Brak oczekujących zastępstw" android:visibility="gone" />
                        <androidx.recyclerview.widget.RecyclerView android:id="@+id/zastepstwa_oczekujace_recycler" android:layout_width="match_parent" android:layout_height="200dp" />
                        
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Zaakceptowane" android:textStyle="bold" android:layout_marginTop="16dp" />
                        <ProgressBar android:id="@+id/zastepstwa_zaakceptowane_progress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone" />
                        <TextView android:id="@+id/zastepstwa_zaakceptowane_empty_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Brak zaakceptowanych zastępstw" android:visibility="gone" />
                        <androidx.recyclerview.widget.RecyclerView android:id="@+id/zastepstwa_zaakceptowane_recycler" android:layout_width="match_parent" android:layout_height="200dp" />
                    </LinearLayout>

                    <!-- Polecenie Container -->
                    <LinearLayout
                        android:id="@+id/polecenie_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="gone">
                        <Button android:id="@+id/btn_polecenie_sobota" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Polecenie pracy: Sobota" style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                        <Button android:id="@+id/btn_polecenie_niedziela" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Polecenie pracy: Niedziela" style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/include_drawer"
        layout="@layout/nav_drawer_content" />

</androidx.drawerlayout.widget.DrawerLayout>